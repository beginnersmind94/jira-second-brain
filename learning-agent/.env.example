# Anthropic auth is handled by Claude Code.
#
# For normal local use, run Claude Code interactively and use /login. Claude
# Code stores subscription OAuth credentials under your user profile.
#
# For non-interactive scripts/CI where browser login is unavailable, run:
#   claude setup-token
# Then copy the printed token into CLAUDE_CODE_OAUTH_TOKEN. setup-token does
# not write the token to .credentials.json for you.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# Leave ANTHROPIC_API_KEY UNSET unless you specifically want to bill against a
# paid Anthropic API key instead of using Claude Code subscription auth.
#
# ANTHROPIC_API_KEY=

# ─── Live Cybersoft Jira (REST) ──────────────────────────────────────
# Required for match_tickets / read_ticket / read_epic. Generate a token at
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://primeroedgenext.atlassian.net
JIRA_EMAIL=your.name@cybersoft.net
JIRA_API_TOKEN=ATATT-replace-with-real-token

# ─── Knowledge base path ─────────────────────────────────────────────
# The search_kb tool reads markdown from the sibling jira-brain repo:
#   <parent>/jira-brain/raw/guides/markdown/**/*.md
#   <parent>/jira-brain/wiki/concepts/*.md
#   <parent>/jira-brain/wiki/workflows/*.md
# Override here if jira-brain is not at the default sibling path.
# JIRA_BRAIN_PATH=C:\Users\you\Downloads\Financials-Documentation-KT\jira-brain
